{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "flux": {
    "enabled": true,
    "fileMatch": ["(^|/)infra/.+\\.yml$", "(^|/)apps/.+\\.yml$", "(^|/)clusters/.+\\.yml$"]
  },
  "packageRules": [
    {
      "description": "Group Grafana/monitoring stack updates",
      "matchPackageNames": [
        "kube-prometheus-stack",
        "prometheus-pushgateway",
        "loki",
        "alloy"
      ],
      "groupName": "monitoring stack",
      "groupSlug": "monitoring-stack",
      "registryUrls": [
        "https://grafana.github.io/helm-charts"
      ]
    },
    {
      "description": "Group stable infra patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "cert-manager",
        "external-dns",
        "external-secrets",
        "cloudnative-pg",
        "k8up",
        "cilium",
        "redis-operator"
      ],
      "groupName": "stable infra patches",
      "groupSlug": "stable-infra-patches"
    },
    {
      "description": "Group FluxCD ecosystem updates",
      "matchPackageNames": [
        "flagger",
        "flagger-loadtester"
      ],
      "groupName": "fluxcd",
      "groupSlug": "fluxcd"
    },
    {
      "description": "Longhorn and OpenBao updates separately - high risk on upgrade",
      "matchPackageNames": [
        "longhorn",
        "openbao",
        "opencost"
      ],
      "groupName": "stateful services",
      "groupSlug": "stateful-services",
      "dependencyDashboardApproval": true
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "vscode-server-dockerized patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "vscode-server-dockerized"
      ],
      "automerge": true
    },
    {
      "description": "Keep podinfo on 6.x range",
      "matchPackageNames": [
        "podinfo"
      ],
      "allowedVersions": "6.x"
    }
  ]
}