{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "hostRules": [
    {
      "matchHost": "raw.githubusercontent.com",
      "token": "{{ secrets.GHCR_TOKEN }}"
    }
  ],
  "flux": {
    "enabled": true,
    "fileMatch": ["(^|/)infra/.+\\.yml$", "(^|/)apps/.+\\.yml$", "(^|/)clusters/.+\\.yml$"]
  },
  "packageRules": [
    {
      "description": "Alloy registry (grafana.github.io)",
      "matchPackageNames": ["alloy"],
      "registryUrls": ["https://grafana.github.io/helm-charts"],
      "groupName": "monitoring stack",
      "groupSlug": "monitoring-stack"
    },
    {
      "description": "Loki registry (grafana-community)",
      "matchPackageNames": ["loki"],
      "registryUrls": ["https://grafana-community.github.io/helm-charts"],
      "groupName": "monitoring stack",
      "groupSlug": "monitoring-stack"
    },
    {
      "description": "Prometheus stack registry (prometheus-community)",
      "matchPackageNames": ["kube-prometheus-stack", "prometheus-pushgateway"],
      "registryUrls": ["https://prometheus-community.github.io/helm-charts"],
      "groupName": "monitoring stack",
      "groupSlug": "monitoring-stack"
    },
    {
      "description": "Group stable infra patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "cert-manager",
        "external-dns",
        "external-secrets",
        "cloudnative-pg",
        "k8up",
        "cilium",
        "redis-operator"
      ],
      "groupName": "stable infra patches",
      "groupSlug": "stable-infra-patches"
    },
    {
      "description": "Group FluxCD ecosystem updates",
      "matchPackageNames": [
        "flagger",
        "flagger-loadtester"
      ],
      "groupName": "fluxcd",
      "groupSlug": "fluxcd",
      "registryUrls": [
        "https://flagger.app"
      ]
    },
    {
      "description": "Longhorn and OpenBao updates separately - high risk on upgrade",
      "matchPackageNames": [
        "longhorn",
        "openbao",
        "opencost"
      ],
      "groupName": "stateful services",
      "groupSlug": "stateful-services",
      "dependencyDashboardApproval": true
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "vscode-server-dockerized updates",
      "matchPackageNames": [
        "vscode-server"
      ],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{2})\\.(?<patch>\\d{2})-(?<build>.+)$"
    },
    {
      "description": "Keep podinfo on 6.x range",
      "matchPackageNames": [
        "podinfo"
      ],
      "allowedVersions": "6.x"
    }
  ]
}